# ============================================================================
# PHP Native Migrator - Environment Configuration
# ============================================================================
# Salin file ini ke .env dan sesuaikan nilainya
# cp .env.example .env  (Linux/Mac)
# copy .env.example .env (Windows)
# ============================================================================

# ─── Database Driver ─────────────────────────────────────────────────────────
# Pilihan: mysql, sqlite
DB_DRIVER=mysql

# ─── MySQL Configuration ─────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nama_database_anda
DB_USERNAME=root
DB_PASSWORD=

# ─── SQLite Configuration ────────────────────────────────────────────────────
# Jika DB_DRIVER=sqlite, set DB_DATABASE ke path file SQLite
# DB_DATABASE=database.sqlite

# ─── App Configuration ───────────────────────────────────────────────────────
# Set ke 'true' untuk menampilkan stack trace saat error
APP_DEBUG=true